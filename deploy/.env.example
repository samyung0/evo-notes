# Docker stack. Copy to deploy/.env — docker-compose auto-loads it.
# Only these are interpolated by docker-compose.yml; DATABASE_URL, BLOB_DIR and
# PIPELINE_URL are wired between the containers inside the compose file.
EVO_PARSER=simple
EVO_ENGINE=linearrag
EVO_EMBEDDER=hash
# Enables Claude chat + VLM image captions across worker + retrieval. Empty = off.
ANTHROPIC_API_KEY=
