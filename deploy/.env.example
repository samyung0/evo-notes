# Docker stack. Copy to deploy/.env — docker-compose auto-loads it.
# DATABASE_URL, BLOB_DIR, REDIS_URL and PIPELINE_URL are wired between the
# containers inside docker-compose.yml; the vars below are interpolated into it.

# ── Modal GPU MineRU parse service (deploy modal/mineru_app.py first) ────────
MODAL_PARSE_URL=
MODAL_PARSE_TOKEN=
EVO_PARSE_METHOD=auto

# ── Embeddings: OpenRouter (Qwen3-Embedding-4B) ─────────────────────────────
# EMBEDDING_DIM is permanent for the vector store — changing it requires
# re-ingesting every file.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
EVO_MODEL_EMBEDDING=qwen/qwen3-embedding-4b
EMBEDDING_DIM=2560

# ── Text LLM: DeepSeek (flash for ingest, pro/flash for query) ──────────────
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
EVO_MODEL_EXTRACTION=deepseek-v4-pro
EVO_QUERY_MODEL=deepseek-v4-pro
EVO_QUERY_MODEL_ALT=deepseek-v4-flash

# ── Vision / image captions: Gemini (OpenAI-compatible endpoint) ────────────
GOOGLE_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
EVO_MODEL_IMAGE_CAPTION=gemini-3.1-flash-lite-preview

# ── Misc ────────────────────────────────────────────────────────────────────
EVO_LIGHTRAG_CACHE_SIZE=16
# Job payload labels (informational; worker always uses RAG-Anything + Modal).
EVO_PARSER=mineru
EVO_ENGINE=raganything
