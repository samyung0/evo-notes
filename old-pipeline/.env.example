# Python worker + retrieval service. NOT auto-loaded — `export` these, run via
# docker-compose, or use `uv run --env-file .env -- <cmd>`. Lists every var
# pipeline/config.py reads.
DATABASE_URL=postgres://evo:evo@localhost:5432/evo?sslmode=disable
BLOB_DIR=./data/blobs

# Pinned pair at deploy. parser: simple|docling|mineru  engine: dense|linearrag|lightrag
# NOTE: lightrag builds an LLM knowledge graph at ingest and REQUIRES a configured
# extraction model (DEEPSEEK_API_KEY etc.); without one, lightrag ingest jobs fail.
EVO_PARSER=simple
EVO_ENGINE=linearrag

# Embeddings: hash (offline dev) | st (local sentence-transformers; .[embed]) |
# remote (OpenAI-compatible /embeddings via the embedding-role provider; .[providers]).
# NOTE: the active embedding model's dimension (EmbeddingModelSpec.dimensions in
# config.py, 2560 for Qwen3-Embedding-4B) must match halfvec(N) in the migrations;
# changing the embedding model requires re-ingesting every file.
EVO_EMBEDDER=hash
EVO_ST_MODEL=Qwen/Qwen3-Embedding-4B

# ── Role-based LLM providers (install .[providers]) ─────────────────────────
# OpenRouter + DeepSeek are OpenAI-compatible; Gemini uses google-genai.
OPENROUTER_API_KEY=
DEEPSEEK_API_KEY=
GOOGLE_API_KEY=
# Optional base_url overrides:
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# Per-role model id overrides (defaults live in config.py ModelConfig):
# EVO_MODEL_EMBEDDING=qwen/qwen3-embedding-4b
# EVO_MODEL_EXTRACTION=deepseek-v4-flash
# EVO_MODEL_KEYWORDS=deepseek-v4-flash
# EVO_MODEL_IMAGE_CAPTION=models/gemini-3.1-flash-lite-preview
# EVO_MODEL_RETRIEVAL=deepseek-v4-pro
# Per-role provider overrides (openrouter | deepseek | gemini | anthropic):
# EVO_PROVIDER_EXTRACTION=deepseek

# Legacy Anthropic path (used only when a role routes to provider 'anthropic').
ANTHROPIC_API_KEY=
EVO_LLM_MODEL=claude-haiku-4-5-20251001
EVO_VLM_MODEL=claude-haiku-4-5-20251001

# Worker queue poll cadence (seconds) and passage chunk target (characters).
EVO_POLL_INTERVAL=2.0
EVO_CHUNK_CHARS=900
