{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "ui_kits/web-app/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Fustat))/i]",
        "message": "Font not provided by the design system. Available: Fustat."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|name|size|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: src, name, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|uppercase|size|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: tone, uppercase, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|course|workspace|success|info|warning|error|purple|green|dark)$/]",
        "message": "<Badge> tone must be one of 'neutral' | 'course' | 'workspace' | 'success' | 'info' | 'warning' | 'error' | 'purple' | 'green' | 'dark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Badge> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|iconLeft|iconRight|fullWidth|disabled|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, iconLeft, iconRight, fullWidth, disabled."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|accent|outline|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'accent' | 'outline' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:padding|radius|interactive|raised|dashed|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: padding, radius, interactive, raised, dashed."
      },
      {
        "selector": "JSXOpeningElement[name.name='Checkbox'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|onChange|size|tone|style|key|ref|className|style|children)$/]",
        "message": "<Checkbox> doesn't accept that prop. Declared props: checked, onChange, size, tone, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Checkbox'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:dark|blue|green|purple)$/]",
        "message": "<Checkbox> tone must be one of 'dark' | 'blue' | 'green' | 'purple'."
      },
      {
        "selector": "JSXOpeningElement[name.name='DashboardScreen'] > JSXAttribute > JSXIdentifier[name!=/^(?:onNavigate|key|ref|className|style|children)$/]",
        "message": "<DashboardScreen> doesn't accept that prop. Declared props: onNavigate."
      },
      {
        "selector": "JSXOpeningElement[name.name='FlashcardsScreen'] > JSXAttribute > JSXIdentifier[name!=/^(?:onNavigate|key|ref|className|style|children)$/]",
        "message": "<FlashcardsScreen> doesn't accept that prop. Declared props: onNavigate."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|strokeWidth|color|style|key|ref|className|style|children)$/]",
        "message": "<Icon> doesn't accept that prop. Declared props: name, size, strokeWidth, color, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute[name.name='name'] > Literal[value!=/^(?:dashboard|workspaces|practice|schedule|files|tasks|notes|profile|settings|logout|search|bell|plus|minus|chevronDown|chevronRight|chevronLeft|arrowRight|upload|send|sparkles|check|more|message|book|flashcards|quiz|x|filter|clock)$/]",
        "message": "<Icon> name must be one of 'dashboard' | 'workspaces' | 'practice' | 'schedule' | 'files' | 'tasks' | 'notes' | 'profile' | 'settings' | 'logout' | 'search' | 'bell' | 'plus' | 'minus' | 'chevronDown' | 'chevronRight' | 'chevronLeft' | 'arrowRight' | 'upload' | 'send' | 'sparkles' | 'check' | 'more' | 'message' | 'book' | 'flashcards' | 'quiz' | 'x' | 'filter' | 'clock'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|variant|size|dot|disabled|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: icon, variant, size, dot, disabled."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:dark|accent|outline|ghost)$/]",
        "message": "<IconButton> variant must be one of 'dark' | 'accent' | 'outline' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<IconButton> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|size|style|inputStyle|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: icon, size, style, inputStyle."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Input> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='NoteCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|body|date|theme|onMenu|key|ref|className|style|children)$/]",
        "message": "<NoteCard> doesn't accept that prop. Declared props: title, body, date, theme, onMenu."
      },
      {
        "selector": "JSXOpeningElement[name.name='NoteCard'] > JSXAttribute[name.name='theme'] > Literal[value!=/^(?:green|purple|greenSoft|purpleSoft)$/]",
        "message": "<NoteCard> theme must be one of 'green' | 'purple' | 'greenSoft' | 'purpleSoft'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|tone|height|showLabel|key|ref|className|style|children)$/]",
        "message": "<ProgressBar> doesn't accept that prop. Declared props: value, tone, height, showLabel."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressBar'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:green|purple|blue|amber|coral|dark)$/]",
        "message": "<ProgressBar> tone must be one of 'green' | 'purple' | 'blue' | 'amber' | 'coral' | 'dark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='QuizScreen'] > JSXAttribute > JSXIdentifier[name!=/^(?:onNavigate|key|ref|className|style|children)$/]",
        "message": "<QuizScreen> doesn't accept that prop. Declared props: onNavigate."
      },
      {
        "selector": "JSXOpeningElement[name.name='ScheduleScreen'] > JSXAttribute > JSXIdentifier[name!=/^(?:onNavigate|key|ref|className|style|children)$/]",
        "message": "<ScheduleScreen> doesn't accept that prop. Declared props: onNavigate."
      },
      {
        "selector": "JSXOpeningElement[name.name='SegmentedOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|key|ref|className|style|children)$/]",
        "message": "<SegmentedOption> doesn't accept that prop. Declared props: value, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='Sidebar'] > JSXAttribute > JSXIdentifier[name!=/^(?:active|collapsed|onNavigate|style|key|ref|className|style|children)$/]",
        "message": "<Sidebar> doesn't accept that prop. Declared props: active, collapsed, onNavigate, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Sidebar'] > JSXAttribute[name.name='active'] > Literal[value!=/^(?:dashboard|workspaces|practice|schedule|files|tasks|notes|profile|settings|logout)$/]",
        "message": "<Sidebar> active must be one of 'dashboard' | 'workspaces' | 'practice' | 'schedule' | 'files' | 'tasks' | 'notes' | 'profile' | 'settings' | 'logout'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Switch'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|onChange|style|key|ref|className|style|children)$/]",
        "message": "<Switch> doesn't accept that prop. Declared props: checked, onChange, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TabItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|key|ref|className|style|children)$/]",
        "message": "<TabItem> doesn't accept that prop. Declared props: value, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='WorkspaceOpenScreen'] > JSXAttribute > JSXIdentifier[name!=/^(?:onNavigate|onBack|initialMode|key|ref|className|style|children)$/]",
        "message": "<WorkspaceOpenScreen> doesn't accept that prop. Declared props: onNavigate, onBack, initialMode."
      },
      {
        "selector": "JSXOpeningElement[name.name='WorkspaceOpenScreen'] > JSXAttribute[name.name='initialMode'] > Literal[value!=/^(?:Chat|Generate)$/]",
        "message": "<WorkspaceOpenScreen> initialMode must be one of 'Chat' | 'Generate'."
      },
      {
        "selector": "JSXOpeningElement[name.name='WorkspaceItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:id|name|type|key|ref|className|style|children)$/]",
        "message": "<WorkspaceItem> doesn't accept that prop. Declared props: id, name, type."
      },
      {
        "selector": "JSXOpeningElement[name.name='WorkspaceItem'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:course|workspace)$/]",
        "message": "<WorkspaceItem> type must be one of 'course' | 'workspace'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
