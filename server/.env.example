# Go gateway. NOTE: the binary does NOT auto-load this file — `export` these
# (or run via deploy/docker-compose.yml). Lists every var cmd/api/main.go reads.
DATABASE_URL=postgres://evo:evo@localhost:5432/evo?sslmode=disable
ADDR=:8080
MIGRATE=true

# Backblaze B2 is required. Endpoint + region come from the bucket page.
B2_ENDPOINT=https://s3.us-west-004.backblazeb2.com
B2_REGION=us-west-004
B2_BUCKET=evo-notes-blobs
B2_KEY_ID=
B2_APP_KEY=
# B2_FORCE_PATH_STYLE=false
# B2_PRESIGN_TTL=900          # raw-file presigned URL lifetime, seconds
PIPELINE_URL=http://localhost:8001
REDIS_URL=redis://localhost:6379/0
EVO_PARSER=mineru
EVO_ENGINE=lightrag

# App URL for Stripe redirects and OAuth return links (frontend origin)
APP_URL=http://localhost:5173

# Clerk — leave empty + AUTH_DISABLED=true for local dev without Clerk
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=
AUTH_DISABLED=true
DEV_USER_ID=u_1

# Stripe (test mode keys from dashboard.stripe.com)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_TEAM=

# Google Drive / OneDrive OAuth is managed by Clerk (external accounts).
# Configure the Google/Microsoft SSO connections with custom credentials and
# the extra scopes (drive.readonly, Files.Read) on the Clerk dashboard.
