# Go gateway. NOTE: the binary does NOT auto-load this file — `export` these
# (or run via deploy/docker-compose.yml). Lists every var cmd/api/main.go reads.
DATABASE_URL=postgres://evo:evo@localhost:5432/evo?sslmode=disable
ADDR=:8080
MIGRATE=true

# Blob storage backend: "disk" (local dev, writes to BLOB_DIR) or "b2"/"s3"
# (production Backblaze B2 / S3-compatible bucket). When b2/s3, the B2_* vars
# below are required and BLOB_DIR is ignored.
BLOB_BACKEND=disk
BLOB_DIR=./data/blobs
# Backblaze B2 (S3-compatible). Endpoint + region come from the bucket page.
# B2_ENDPOINT=https://s3.us-west-004.backblazeb2.com
# B2_REGION=us-west-004
# B2_BUCKET=evo-notes-blobs
# B2_KEY_ID=
# B2_APP_KEY=
# B2_FORCE_PATH_STYLE=false   # set true only for MinIO-style endpoints
# B2_PRESIGN_TTL=900          # raw-file presigned URL lifetime, seconds
PIPELINE_URL=http://localhost:8001
REDIS_URL=redis://localhost:6379/0
EVO_PARSER=mineru
EVO_ENGINE=raganything

# App URL for Stripe redirects and OAuth return links (frontend origin)
APP_URL=http://localhost:5173

# Clerk — leave empty + AUTH_DISABLED=true for local dev without Clerk
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=
AUTH_DISABLED=true
DEV_USER_ID=u_1

# Stripe (test mode keys from dashboard.stripe.com)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_TEAM=

# Google Drive OAuth (separate from Clerk sign-in)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# OneDrive / Microsoft Graph OAuth
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=

# Gateway base URL for OAuth redirect URIs (not the frontend)
OAUTH_REDIRECT_BASE_URL=http://localhost:8080
