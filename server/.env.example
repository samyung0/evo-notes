# Go gateway. NOTE: the binary does NOT auto-load this file — `export` these
# (or run via deploy/docker-compose.yml). Lists every var cmd/api/main.go reads.
DATABASE_URL=postgres://evo:evo@localhost:5432/evo?sslmode=disable
ADDR=:8080
# Apply embedded migrations + seed on startup (idempotent). Set false to skip.
MIGRATE=true
# Shared upload dir: the gateway writes blobs here, the worker reads them.
BLOB_DIR=./data/blobs
# Python retrieval service. Empty -> chat/generate fall back to local placeholders.
PIPELINE_URL=http://localhost:8001
# Pinned pair recorded on each upload so the worker knows what to run.
EVO_PARSER=docling
EVO_ENGINE=linearrag
