{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "evo-mineru-relay",
  "main": "src/index.js",
  "compatibility_date": "2026-07-16",
  "vars": {
    "B2_HOST": "s3.YOUR_B2_REGION.backblazeb2.com",
    "MINERU_UPLOAD_HOSTS": ".aliyuncs.com",
    "MAX_BYTES": "10485760",
    "RELAY_TIMEOUT_MS": "120000",
  },
}
