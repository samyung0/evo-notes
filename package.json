{
  "name": "evo-notes",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "gen:openapi": "cd server && go run ./cmd/openapi -o ../openapi.yaml",
    "gen:api": "orval",
    "gen:api:msw": "pnpm gen:openapi && pnpm gen:api",
    "gen:api:watch": "orval --watch"
  },
