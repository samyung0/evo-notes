# Python worker + retrieval service. NOT auto-loaded — `export` these, run via
# docker-compose, or use `uv run --env-file .env -- <cmd>`. Lists every var
# pipeline/config.py reads.
DATABASE_URL=postgres://evo:evo@localhost:5432/evo?sslmode=disable
BLOB_DIR=./data/blobs

# Pinned pair at deploy. parser: simple|docling|mineru  engine: dense|linearrag|lightrag
EVO_PARSER=simple
EVO_ENGINE=linearrag

# Embeddings: hash (offline dev, no ML deps) | st (sentence-transformers; .[embed])
EVO_EMBEDDER=hash
EVO_ST_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Anthropic Claude for chat + image captions. Empty -> extractive fallbacks.
ANTHROPIC_API_KEY=
EVO_LLM_MODEL=claude-haiku-4-5-20251001
EVO_VLM_MODEL=claude-haiku-4-5-20251001

# Worker queue poll cadence (seconds) and passage chunk target (characters).
EVO_POLL_INTERVAL=2.0
EVO_CHUNK_CHARS=900
