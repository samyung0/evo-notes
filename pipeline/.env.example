# Python worker + retrieval service config. NOT auto-loaded — export these, use
# docker-compose, or `uv run --env-file .env -- <cmd>`. Lists every var the
# pipeline reads (pipeline/config.py).

# ── Shared infra ────────────────────────────────────────────────────────────
DATABASE_URL=postgres://evo:evo@localhost:5432/evo?sslmode=disable
BLOB_DIR=./data/blobs
REDIS_URL=redis://localhost:6379/0
# LightRAG still wants a working-dir handle even with Postgres backends.
WORKING_DIR=/data/rag_storage

# LightRAG's Postgres storages read DISCRETE vars (NOT the DATABASE_URL). These
# are auto-derived from DATABASE_URL at startup; override only if they differ.
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_USER=evo
# POSTGRES_PASSWORD=evo
# POSTGRES_DATABASE=evo
# 2560-dim embeddings need halfvec HNSW indexes (pgvector >= 0.7.0). Auto-pinned;
# do not change unless you also change EMBEDDING_DIM.
# POSTGRES_VECTOR_INDEX_TYPE=HNSW_HALFVEC

# ── Worker ──────────────────────────────────────────────────────────────────
EVO_POLL_INTERVAL=2.0
EVO_LIGHTRAG_CACHE_SIZE=16

# ── Modal MineRU GPU parse service ──────────────────────────────────────────
MODAL_PARSE_URL=
MODAL_PARSE_TOKEN=
EVO_PARSE_METHOD=auto

# ── Embeddings: OpenRouter (OpenAI-compatible /embeddings) ──────────────────
# NOTE: EMBEDDING_DIM is permanent for a vector store — changing it requires
# re-ingesting every file. 2560 = Qwen3-Embedding-4B native size.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
EVO_MODEL_EMBEDDING=qwen/qwen3-embedding-4b
EMBEDDING_DIM=2560

# ── Text LLM: DeepSeek (OpenAI-compatible) ──────────────────────────────────
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
# Ingest extraction uses the cheap model; query defaults to pro with flash
# selectable per request.
EVO_MODEL_EXTRACTION=deepseek-v4-flash
EVO_QUERY_MODEL=deepseek-v4-pro
EVO_QUERY_MODEL_ALT=deepseek-v4-flash

# ── Vision / image captions: Gemini (OpenAI-compatible endpoint) ────────────
GOOGLE_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
EVO_MODEL_IMAGE_CAPTION=gemini-3.1-flash-lite-preview
