# Frontend (Vite). Copy to .env.local. Only VITE_-prefixed vars reach the app.
#
# MSW mocks are ON by default; set false to hit the real Go gateway. In dev the
# Vite proxy forwards /api -> http://localhost:8080 (see vite.config.ts), so no
# API base URL is needed.
VITE_USE_MSW=false

# Frontend port
VITE_PORT=5173

# Backend URL
VITE_API_URL=http://localhost:8080
