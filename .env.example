# Frontend (Vite). Copy to .env.local. Only VITE_-prefixed vars reach the app.
#
# MSW mocks are ON by default in development. Set false to hit the real Go gateway
# with Clerk auth. Vite proxies /api -> VITE_API_URL (see vite.config.ts).
VITE_USE_MSW=true

VITE_PORT=5173
VITE_API_URL=http://localhost:8080

# Clerk (required when VITE_USE_MSW=false)
VITE_CLERK_PUBLISHABLE_KEY=

# Optional — Stripe.js not used yet; checkout redirects server-side
VITE_STRIPE_PUBLISHABLE_KEY=

# Optional — Direct B2 upload. If true, the app will upload files directly to B2 instead of using the proxy.
# This is useful if you want to bypass the proxy and upload files directly to B2.
VITE_DIRECT_B2_UPLOAD=true